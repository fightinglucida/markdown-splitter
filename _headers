/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://fonts.loli.net; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.loli.net https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://images.weserv.nl https://corsproxy.io https://api.allorigins.win;

/*.html
  Cache-Control: no-store, no-cache, must-revalidate

/themes/*.json
  Cache-Control: no-store, no-cache, must-revalidate
