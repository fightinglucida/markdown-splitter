{
  "name": "markdown-card-local-client",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop client for batch rendering Markdown files into card images.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5188 && electron .\"",
    "build": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "html-to-image": "^1.11.11",
    "jszip": "^3.10.1",
    "marked": "^12.0.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {}
}
