{
  "name": "书香墨韵",
  "preview": {
    "description": "作者开场的极简长文多图",
    "features": ["头像作者", "大字号正文", "右下页码"]
  },
  "config": {
    "title": {
      "show": false,
      "editable": false,
      "fontSize": "0",
      "fontFamily": "-apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      "fontWeight": "800",
      "color": "#1a1a1a",
      "textAlign": "left",
      "marginBottom": "0"
    },
    "content": {
      "show": true,
      "editable": true,
      "fontSize": "20px",
      "fontFamily": "JetBrains Mono",
      "color": "#000000",
      "textAlign": "left",
      "lineHeight": "1.48",
      "maxCharsPerLine": 22,
      "backgroundColor": "transparent",
      "backdropFilter": "none",
      "padding": "0 0 34px",
      "borderRadius": "0"
    },
    "author": {
      "show": true,
      "editable": true,
      "position": "top-left",
      "avatarSize": "58px",
      "nicknameSize": "21px",
      "nicknameColor": "#1a1a1a",
      "usernameSize": "14px",
      "usernameColor": "#555555",
      "allowCustomAvatar": true,
      "allowSocialIcon": true
    },
    "time": {
      "show": true,
      "editable": true,
      "position": "bottom-left",
      "format": "MM/DD",
      "fontSize": "18px",
      "color": "#111111"
    },
    "pageNumber": {
      "show": true,
      "editable": true,
      "position": "bottom-right",
      "format": "single",
      "fontSize": "18px",
      "color": "#111111"
    },
    "watermark": {
      "show": false,
      "editable": false,
      "position": "none",
      "text": "",
      "fontSize": "0",
      "color": "transparent",
      "opacity": 0
    },
    "canvas": {
      "ratio": "3:4",
      "background": "#fbfbf7",
      "padding": 48,
      "borderRadius": 0,
      "canvasScale": 80,
      "bgType": "light"
    },
    "markdown": {
      "h2": {
        "fontSize": "20px",
        "padding": "0.3em 1em",
        "borderRadius": "30px",
        "boxShadow": "0 4px 6px rgba(0, 0, 0, 0.1)"
      },
      "h3": {
        "fontSize": "18px",
        "borderLeft": "5px solid #1a1a1a",
        "paddingLeft": "20px",
        "background": "linear-gradient(to right, rgba(26, 26, 26, 0.04), transparent 50%)"
      },
      "strong": {
        "background": "linear-gradient(to bottom, transparent 65%, rgba(255, 235, 59, 0.7) 65%)",
        "color": "#1a1a1a"
      },
      "blockquote": {
        "background": "#f8f8f8",
        "borderLeft": "5px solid #eee",
        "color": "#888"
      }
    }
  }
}
